<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>$(BundledNetCoreAppTargetFramework)</TargetFramework>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    <PackageReference Include="Microsoft.Ess.EsrpCli" GeneratePathProperty="true" ExcludeAssets="all" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Microsoft.DotNet.RecursiveSigning\Microsoft.DotNet.RecursiveSigning.csproj" />
  </ItemGroup>

  <!-- Copy ESRP CLI tool binaries to output under ESRPCLI/ subdirectory -->
  <ItemGroup>
    <None Include="$(PkgMicrosoft_Ess_EsrpCli)\tools\net8.0\**\*"
          CopyToOutputDirectory="PreserveNewest"
          Link="ESRPCLI\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- Include ESRP CLI binaries in the NuGet package -->
  <PropertyGroup>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);IncludeEsrpCliInPackage</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <Target Name="IncludeEsrpCliInPackage">
    <ItemGroup>
      <TfmSpecificPackageFile Include="$(PkgMicrosoft_Ess_EsrpCli)\tools\net8.0\**\*"
                              PackagePath="lib\$(TargetFramework)\ESRPCLI\" />
    </ItemGroup>
  </Target>

</Project>
