<Project>

  <PropertyGroup>
    <MicrosoftDotNetBuildTasksFileCatalogTaskAssembly Condition="'$(MSBuildRuntimeType)' == 'Core'">$(MSBuildThisFileDirectory)..\tools\net\Microsoft.DotNet.Build.Tasks.FileCatalog.dll</MicrosoftDotNetBuildTasksFileCatalogTaskAssembly>
    <MicrosoftDotNetBuildTasksFileCatalogTaskAssembly Condition="'$(MSBuildRuntimeType)' != 'Core'">$(MSBuildThisFileDirectory)..\tools\netframework\Microsoft.DotNet.Build.Tasks.FileCatalog.dll</MicrosoftDotNetBuildTasksFileCatalogTaskAssembly>
  </PropertyGroup>

  <UsingTask TaskName="Microsoft.DotNet.Build.Tasks.FileCatalog.GenerateFileCatalog" AssemblyFile="$(MicrosoftDotNetBuildTasksFileCatalogTaskAssembly)" />

</Project>
