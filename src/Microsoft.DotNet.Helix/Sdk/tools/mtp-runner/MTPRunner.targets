<Project>

  <!--
    Microsoft.Testing.Platform (MTP) test projects are self-hosting executables produced via
    Microsoft.Testing.Platform.MSBuild. The Helix Sdk publishes them and runs the resulting
    assembly directly with 'dotnet exec'. The publish helper is the generic
    xunit-runner/XUnitPublish.targets file (it only defines a 'PublishWithOutput' helper
    target and is intentionally framework-agnostic).

    Use <MTPProject Include="...csproj" /> for any MTP-based test project (MSTest 4.x,
    xUnit v3 with MTP, NUnit with MTP, TUnit, custom MTP).

    Test projects must reference 'Microsoft.Testing.Extensions.TrxReport' so that the work
    item command can produce a TRX file. Projects using 'MSTest.Sdk' include it by default;
    xUnit v3 projects built with Microsoft.DotNet.Arcade.Sdk's XUnitV3 targets pick it up
    implicitly as well. Other MTP-based frameworks must add the package manually.
  -->

  <PropertyGroup>
    <_MTPPublishTargetsPath>$(MSBuildThisFileDirectory)../xunit-runner/XUnitPublish.targets</_MTPPublishTargetsPath>
    <!--
      Name of the TRX file produced by Microsoft.Testing.Extensions.TrxReport. The arcade
      Python TRXFormat parser (and EnableHelixJobMonitor's *.trx sweep) will pick up any
      *.trx in the work item working directory, so the exact name only matters if the user
      has multiple consumers expecting a specific filename.
    -->
    <MTPTrxReportFilename Condition="'$(MTPTrxReportFilename)' == ''">testResults.trx</MTPTrxReportFilename>
  </PropertyGroup>

  <Target Name="RestoreMTPProjects"
          Condition="'@(MTPProject)' != ''"
          BeforeTargets="Restore"
          Outputs="%(MTPProject.Identity)%(MTPProject.AdditionalProperties)">
    <MSBuild Projects="%(MTPProject.Identity)"
             Targets="Restore"
             Properties="CustomAfterMicrosoftCommonTargets=$(_MTPPublishTargetsPath);%(MTPProject.AdditionalProperties)">
    </MSBuild>
  </Target>

  <Target Name="BuildMTPProjects"
          Condition="'@(MTPProject)' != ''"
          BeforeTargets="CoreBuild"
          Outputs="%(MTPProject.Identity)%(MTPProject.AdditionalProperties)">
    <PropertyGroup>
      <_CurrentMTPProject>%(MTPProject.Identity)</_CurrentMTPProject>
      <_CurrentMTPAdditionalProperties>%(MTPProject.AdditionalProperties)</_CurrentMTPAdditionalProperties>
    </PropertyGroup>
    <MSBuild Projects="$(_CurrentMTPProject)" Targets="PublishWithOutput" Properties="CustomAfterMicrosoftCommonTargets=$(_MTPPublishTargetsPath);$(_CurrentMTPAdditionalProperties)">
      <Output TaskParameter="TargetOutputs" PropertyName="_MTPPublishOutputDir" />
    </MSBuild>
    <MSBuild Projects="$(_CurrentMTPProject)" Targets="GetTargetPath" Properties="CustomAfterMicrosoftCommonTargets=$(_MTPPublishTargetsPath);$(_CurrentMTPAdditionalProperties)">
      <Output TaskParameter="TargetOutputs" PropertyName="_MTPTargetPath" />
    </MSBuild>

    <ItemGroup>
      <MTPProject Condition="'%(Identity)' == '$(_CurrentMTPProject)'">
        <PublishDirectory>$(_MTPPublishOutputDir)</PublishDirectory>
        <TargetPath>$(_MTPTargetPath)</TargetPath>
      </MTPProject>
    </ItemGroup>
  </Target>

  <Target Name="CreateMTPWorkItems"
          Condition="'@(MTPProject)' != ''"
          BeforeTargets="CoreTest">
    <CreateMTPWorkItems MTPProjects="@(MTPProject)"
                        IsPosixShell="$(IsPosixShell)"
                        MTPWorkItemTimeout="$(MTPWorkItemTimeout)"
                        TrxReportFilename="$(MTPTrxReportFilename)">
      <Output TaskParameter="MTPWorkItems" ItemName="HelixWorkItem"/>
    </CreateMTPWorkItems>
  </Target>

</Project>
