<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>$(NetMinimum)</TargetFramework>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>

    <IsPackable>true</IsPackable>
    <IsBuildTaskProject>true</IsBuildTaskProject>

    <!-- Generate package during Build, rather than Pack, so that it can be used during Test. -->
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>

    <Description>Common toolset for repositories</Description>
    <PackageTags>Arcade Build Repository Toolset MSBuild SDK</PackageTags>
    <DevelopmentDependency>true</DevelopmentDependency>
    <PackageType>MSBuildSdk</PackageType>

    <EnableDefaultNoneItems>false</EnableDefaultNoneItems>
    <_GeneratedVersionFilePath>$(IntermediateOutputPath)DefaultVersions.Generated.props</_GeneratedVersionFilePath>
    <NoWarn>$(NoWarn);3021;NU5100;NU5105;NU5111;SYSLIB0013</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Build" />
    <PackageReference Include="Microsoft.Build.Tasks.Core" />
    <PackageReference Include="NuGet.Versioning" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Microsoft.DotNet.Arcade.Sdk.Tests" />
  </ItemGroup>

  <ItemGroup>
    <None Include="sdk/Sdk.props;sdk/Sdk.targets"
          Pack="true"
          PackagePath="sdk/%(Filename)%(Extension)" />
    <None Include="tools/**/*.*"
          Pack="true"
          PackagePath="tools/%(RecursiveDir)%(Filename)%(Extension)" />
    <None Include="$(_GeneratedVersionFilePath)"
          Pack="true"
          PackagePath="tools\DefaultVersions.Generated.props" />
    <None Include="toolset/**/*.*"
          Pack="true"
          PackagePath="toolset/%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Common\Microsoft.Arcade.Common\Microsoft.Arcade.Common.csproj" />
    <ProjectReference Include="..\Microsoft.DotNet.ArcadeLogging\Microsoft.DotNet.ArcadeLogging.csproj"
      ReferenceOutputAssembly="false"
      SkipGetTargetFrameworkProperties="true"
      Publish="false"
      Private="false"
      PrivateAssets="all"
      ExcludeAssets="runtime" />
  </ItemGroup>

  <!--
    Build-order-only references to the other in-repo packages that the Arcade SDK's props/targets
    consume at the Arcade SDK version (pinned in tools/DefaultVersions.props and
    toolset/Directory.Packages.props). These are pure ordering references (no assembly or package
    dependency thanks to ReferenceOutputAssembly="false" + PrivateAssets="all"); the Targets metadata
    also packs each referenced project during this project's build, so the freshly built packages land
    in the local feed. This lets repos building against the just-produced Arcade SDK — e.g.
    src/Microsoft.DotNet.Arcade.Validation.Tests — restore them from a plain `build.cmd` without a
    separate `-pack`.
    Don't define the "dependencies" when building source-only to avoid trying to build projects that
    are actually filtered out.
  -->
  <ItemGroup Condition="'$(DotNetBuildSourceOnly)' != 'true'">
    <ProjectReference Include="..\Microsoft.DotNet.XliffTasks\Microsoft.DotNet.XliffTasks.csproj;
                               ..\Microsoft.DotNet.SignTool\Microsoft.DotNet.SignTool.csproj;
                               ..\Microsoft.DotNet.Build.Tasks.Feed\Microsoft.DotNet.Build.Tasks.Feed.csproj;
                               ..\Microsoft.DotNet.NuGetRepack\tasks\Microsoft.DotNet.NuGetRepack.Tasks.csproj;
                               ..\Microsoft.DotNet.SignCheckTask\Microsoft.DotNet.SignCheckTask.csproj;
                               ..\Microsoft.DotNet.SourceBuild\tasks\Microsoft.DotNet.SourceBuild.Tasks.csproj;
                               ..\Microsoft.DotNet.Baselines.Tasks\Microsoft.DotNet.Baselines.Tasks.csproj;
                               ..\Microsoft.DotNet.Build.Tasks.Installers\Microsoft.DotNet.Build.Tasks.Installers.csproj;
                               ..\Microsoft.DotNet.Build.Tasks.VisualStudio\Microsoft.DotNet.Build.Tasks.VisualStudio.csproj;
                               ..\Microsoft.DotNet.MacOsPkg\Cli\Microsoft.DotNet.MacOsPkg.Cli.csproj"
                      Targets="Build;Pack"
                      ReferenceOutputAssembly="false"
                      SkipGetTargetFrameworkProperties="true"
                      PrivateAssets="all" />
  </ItemGroup>

  <Target Name="_GenerateSdkVersionFile" Inputs="$(MSBuildAllProjects)" Outputs="$(_GeneratedVersionFilePath)" BeforeTargets="GenerateNuSpec">
    <PropertyGroup>
      <_SdkVersionPropsContent>
<![CDATA[<!-- Generated by $(MSBuildThisFile) -->
<!-- Licensed to the .NET Foundation under one or more agreements. The .NET Foundation licenses this file to you under the MIT license. See the LICENSE file in the project root for more information. -->
<Project>

  <PropertyGroup>
    <ArcadeSdkVersion>$(PackageVersion)</ArcadeSdkVersion>
    <MicrosoftNetCompilersToolsetVersion>$(MicrosoftNetCompilersToolsetVersion)</MicrosoftNetCompilersToolsetVersion>
    <MicrosoftDiaSymReaderPdb2PdbVersion>$(MicrosoftDiaSymReaderPdb2PdbVersion)</MicrosoftDiaSymReaderPdb2PdbVersion>
    <MicrosoftDotNetXliffTasksVersion>$(PackageVersion)</MicrosoftDotNetXliffTasksVersion>
    <MicrosoftSymbolUploaderBuildTaskVersion>$(MicrosoftSymbolUploaderBuildTaskVersion)</MicrosoftSymbolUploaderBuildTaskVersion>
    <MicrosoftTemplateEngineAuthoringTasksVersion>$(MicrosoftTemplateEngineAuthoringTasksVersion)</MicrosoftTemplateEngineAuthoringTasksVersion>
  </PropertyGroup>

</Project>]]>
  </_SdkVersionPropsContent>
    </PropertyGroup>

    <WriteLinesToFile File="$(_GeneratedVersionFilePath)" Lines="$(_SdkVersionPropsContent)" Overwrite="true" />

    <ItemGroup>
      <FileWrites Include="$(_GeneratedVersionFilePath)" />
    </ItemGroup>
  </Target>

  <ItemGroup>
    <None Include="$(ArtifactsBinDir)Microsoft.DotNet.ArcadeLogging\$(Configuration)\netstandard2.0\Microsoft.DotNet.ArcadeLogging.dll"
          Pack="true"
          PackagePath="toolset\net\Microsoft.DotNet.ArcadeLogging.dll" />
  </ItemGroup>

</Project>
