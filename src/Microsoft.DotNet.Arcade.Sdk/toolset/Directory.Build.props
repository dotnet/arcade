<Project>

  <PropertyGroup>
    <OutDirName>toolset\$(MSBuildProjectName)</OutDirName>
  </PropertyGroup>

  <Import Project="Sdk.props" Sdk="Microsoft.DotNet.Arcade.Sdk" />

  <PropertyGroup>
    <TargetFramework>$(BundledNETCoreAppTargetFramework)</TargetFramework>

    <!-- Disable target framework filtering for top level projects -->
    <NoTargetFrameworkFiltering>true</NoTargetFrameworkFiltering>

    <_SuppressAllTargets>true</_SuppressAllTargets>
    <_SuppressSdkImports>false</_SuppressSdkImports>
    <_EmptyDisableRestore>false</_EmptyDisableRestore>
  </PropertyGroup>

</Project>
